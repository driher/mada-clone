"use client";

import Image from "next/image";
import { useEffect, useState, useRef } from "react";

export default function GaleriPage() {
  const [posts, setPosts] = useState<any[]>([]);
  const [activeIndex, setActiveIndex] = useState<number | null>(null);

  // touch tracking
  const startX = useRef(0);
  const endX = useRef(0);

  useEffect(() => {
    async function fetchData() {
      try {
        const res = await fetch(
          "https://cms.komunikasi.uinsgd.ac.id/wp-json/wp/v2/posts?_embed&per_page=12&categories=79"
        );
        const data = await res.json();
        setPosts(data);
      } catch {
        setPosts([]);
      }
    }

    fetchData();
  }, []);

  const getImage = (post: any) =>
    post?._embedded?.["wp:featuredmedia"]?.[0]?.media_details?.sizes?.large
      ?.source_url ||
    post?._embedded?.["wp:featuredmedia"]?.[0]?.source_url ||
    "/no-image.jpg";

  const open = (index: number) => setActiveIndex(index);
  const close = () => setActiveIndex(null);

  const next = () => {
    if (activeIndex === null) return;
    setActiveIndex((prev) =>
      prev === posts.length - 1 ? 0 : (prev ?? 0) + 1
    );
  };

  const prev = () => {
    if (activeIndex === null) return;
    setActiveIndex((prev) =>
      prev === 0 ? posts.length - 1 : (prev ?? 0) - 1
    );
  };

  // keyboard support
  useEffect(() => {
    const handleKey = (e: KeyboardEvent) => {
      if (activeIndex === null) return;

      if (e.key === "Escape") close();
      if (e.key === "ArrowRight") next();
      if (e.key === "ArrowLeft") prev();
    };

    window.addEventListener("keydown", handleKey);
    return () => window.removeEventListener("keydown", handleKey);
  }, [activeIndex]);

  // swipe handlers
  const handleTouchStart = (e: React.TouchEvent) => {
    startX.current = e.touches[0].clientX;
  };

  const handleTouchMove = (e: React.TouchEvent) => {
    endX.current = e.touches[0].clientX;
  };

  const handleTouchEnd = () => {
    const diff = startX.current - endX.current;

    if (Math.abs(diff) > 50) {
      if (diff > 0) {
        next(); // swipe left → next
      } else {
        prev(); // swipe right → prev
      }
    }
  };

  return (
    <main className="min-h-screen bg-gradient-to-b from-slate-50 to-white">

      {/* HEADER */}
      <section className="max-w-6xl mx-auto px-4 pt-10 pb-6">
        <h1 className="text-3xl md:text-4xl font-bold text-slate-900">
          📸 Galeri Foto
        </h1>
        <p className="text-slate-500 mt-2">
          Dokumentasi kegiatan dan momen penting
        </p>

        <div className="w-24 h-1 bg-pink-500 rounded-full mt-4" />
      </section>

      {/* GRID */}
      <section className="max-w-6xl mx-auto px-4 pb-16">
        <div className="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">

          {posts.map((post, index) => (
            <div
              key={post.id}
              onClick={() => open(index)}
              className="cursor-pointer group overflow-hidden rounded-xl border bg-white shadow-sm hover:shadow-lg transition"
            >
              <div className="relative w-full h-40">
                <Image
                  src={getImage(post)}
                  alt={post.title?.rendered || "Galeri"}
                  fill
                  className="object-cover group-hover:scale-105 transition duration-300"
                />
              </div>

              <div className="p-2">
                <p className="text-xs text-slate-700 line-clamp-2">
                  {post.title?.rendered}
                </p>
              </div>
            </div>
          ))}

        </div>
      </section>

      {/* LIGHTBOX + SWIPE */}
      {activeIndex !== null && posts[activeIndex] && (
        <div
          className="fixed inset-0 z-50 bg-black/90 flex items-center justify-center"
          onClick={close}
        >

          <div
            className="relative w-full max-w-5xl h-[85vh] px-4"
            onClick={(e) => e.stopPropagation()}
            onTouchStart={handleTouchStart}
            onTouchMove={handleTouchMove}
            onTouchEnd={handleTouchEnd}
          >

            {/* CLOSE */}
            <button
              onClick={close}
              className="absolute top-2 right-2 text-white text-2xl z-50"
            >
              ✕
            </button>

            {/* IMAGE */}
            <div className="relative w-full h-full">
              <Image
                src={getImage(posts[activeIndex])}
                alt="preview"
                fill
                className="object-contain rounded-xl"
                priority
              />
            </div>

            {/* NAV BUTTONS (desktop) */}
            <button
              onClick={prev}
              className="hidden md:block absolute left-2 top-1/2 -translate-y-1/2 text-white text-3xl"
            >
              ‹
            </button>

            <button
              onClick={next}
              className="hidden md:block absolute right-2 top-1/2 -translate-y-1/2 text-white text-3xl"
            >
              ›
            </button>

          </div>
        </div>
      )}

    </main>
  );
}