"use client";

import BigHeroSlider from "@/components/BigHeroSlider";
import NewsModern from "@/components/NewsModern";
import AgendaSlider from "@/components/AgendaSlider";
import PopularLinks from "@/components/PopularLinks";
import AcademicAnnouncement from "@/components/AcademicAnnouncement";
import ProfileCard from "@/components/ProfileCard";

import { useEffect, useState } from "react";

import {
  getKetuaJurusan,
  getSekretarisJurusan,
  getProdiHumas,
  getProdiJurnalistik,
} from "@/lib/api";

type Post = any;

export default function Home() {
  const [beritaPosts, setBeritaPosts] = useState<Post[]>([]);
  const [agendaPosts, setAgendaPosts] = useState<Post[]>([]);
  const [prestasiPosts, setPrestasiPosts] = useState<Post[]>([]);
  const [loading, setLoading] = useState(true);

  const [ketua, setKetua] = useState<any>(null);
  const [sekretaris, setSekretaris] = useState<any>(null);
  const [humas, setHumas] = useState<any>(null);
  const [jurnalistik, setJurnalistik] = useState<any>(null);

  // ================= FETCH DATA =================
  useEffect(() => {
    const run = async () => {
      try {
        const [beritaRes, agendaRes, prestasiRes] = await Promise.all([
          fetch(
            "https://cms.komunikasi.uinsgd.ac.id/wp-json/wp/v2/posts?_embed&per_page=6&categories=44"
          ),
          fetch(
            "https://cms.komunikasi.uinsgd.ac.id/wp-json/wp/v2/posts?_embed&per_page=10&categories=63"
          ),
          fetch(
            "https://cms.komunikasi.uinsgd.ac.id/wp-json/wp/v2/posts?categories=80&_embed&per_page=1"
          ),
        ]);

        const berita = await beritaRes.json();
        const agenda = await agendaRes.json();
        const prestasi = await prestasiRes.json();

        setBeritaPosts(Array.isArray(berita) ? berita : []);
        setAgendaPosts(Array.isArray(agenda) ? agenda : []);
        setPrestasiPosts(Array.isArray(prestasi) ? prestasi : []);

        const [k, s, h, j] = await Promise.all([
          getKetuaJurusan().catch(() => null),
          getSekretarisJurusan().catch(() => null),
          getProdiHumas().catch(() => null),
          getProdiJurnalistik().catch(() => null),
        ]);

        setKetua(k);
        setSekretaris(s);
        setHumas(h);
        setJurnalistik(j);
      } catch (e) {
        console.error(e);
      } finally {
        setLoading(false);
      }
    };

    run();
  }, []);

  const prestasi = prestasiPosts?.[0];

  const getImage = (post: any) =>
    post?._embedded?.["wp:featuredmedia"]?.[0]?.source_url ||
    "/no-image.jpg";

  const getContent = (post: any) =>
    (post?.excerpt?.rendered || post?.content?.rendered || "")
      .replace(/<[^>]*>/g, "")
      .slice(0, 300);

  return (
    <>
      {/* ================= HERO ================= */}
      <section className="w-full overflow-hidden">
        <BigHeroSlider />
      </section>

      {/* ================= CONTENT ================= */}
      <section className="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-10 space-y-10 sm:space-y-14">

        {/* NEWS */}
        <div>
          <h2 className="text-2xl sm:text-3xl font-bold mb-4">📰 Berita</h2>
          <NewsModern posts={beritaPosts} />
        </div>

        {/* AGENDA */}
        <div>
          <h2 className="text-xl sm:text-2xl font-bold mb-4">📅 Agenda</h2>
          <AgendaSlider posts={agendaPosts} />
        </div>

        {/* GRID */}
        <div className="grid grid-cols-1 lg:grid-cols-3 gap-6 items-start">

          {/* PENGUMUMAN */}
          <div className="lg:col-span-2">
            <h2 className="text-xl sm:text-2xl font-bold mb-3">📢 Pengumuman</h2>
            <AcademicAnnouncement />
          </div>

          {/* PRESTASI */}
          {prestasi && (
            <div className="lg:col-span-1">
              <div className="rounded-2xl overflow-hidden shadow-xl w-full h-64 sm:h-72 lg:h-full">
                <img
                  src={getImage(prestasi)}
                  alt="Prestasi"
                  className="w-full h-full object-cover"
                />
              </div>
            </div>
          )}

        </div>

        {/* LINKS */}
        <PopularLinks />

        {/* PROFILE */}
        <div className="space-y-6">

          {ketua && (
            <ProfileCard
              label="Ketua Jurusan"
              name={ketua.title.rendered}
              image={getImage(ketua)}
              content={getContent(ketua)}
              color="green"
            />
          )}

          {sekretaris && (
            <ProfileCard
              label="Sekretaris Jurusan"
              name={sekretaris.title.rendered}
              image={getImage(sekretaris)}
              content={getContent(sekretaris)}
              color="orange"
            />
          )}

          {humas && (
            <ProfileCard
              label="Ketua Prodi Humas"
              name={humas.title.rendered}
              image={getImage(humas)}
              content={getContent(humas)}
              color="pink"
            />
          )}

          {jurnalistik && (
            <ProfileCard
              label="Ketua Prodi Jurnalistik"
              name={jurnalistik.title.rendered}
              image={getImage(jurnalistik)}
              content={getContent(jurnalistik)}
              color="orange"
            />
          )}

        </div>

      </section>
    </>
  );
}