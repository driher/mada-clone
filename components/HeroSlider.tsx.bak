"use client";

import { useEffect, useState, useRef } from "react";

export default function HeroSlider({ posts }: any) {
  const [index, setIndex] = useState(0);
  const intervalRef = useRef<NodeJS.Timeout | null>(null);
  const startX = useRef(0);

  const heroPosts = Array.isArray(posts) ? posts.slice(0, 10) : [];
  const length = heroPosts.length;

  // RESET INDEX kalau data berubah
  useEffect(() => {
    setIndex(0);
  }, [length]);

  // AUTO SLIDE (SAFE VERSION)
  useEffect(() => {
    if (length <= 1) return;

    intervalRef.current = setInterval(() => {
      setIndex((prev) => (prev + 1) % length);
    }, 4000);

    return () => {
      if (intervalRef.current) clearInterval(intervalRef.current);
    };
  }, [length]);

  const nextSlide = () => {
    setIndex((prev) => (prev + 1) % length);
  };

  const prevSlide = () => {
    setIndex((prev) => (prev - 1 + length) % length);
  };

  const handleTouchStart = (e: any) => {
    startX.current = e.touches[0].clientX;
  };

  const handleTouchEnd = (e: any) => {
    const endX = e.changedTouches[0].clientX;

    if (startX.current - endX > 50) nextSlide();
    if (endX - startX.current > 50) prevSlide();
  };

  const getImage = (post: any) =>
    post?._embedded?.["wp:featuredmedia"]?.[0]?.source_url ||
    post?._embedded?.["wp:featuredmedia"]?.[0]?.media_details?.sizes?.large
      ?.source_url ||
    "/no-image.jpg";

  if (length === 0) {
    return (
      <div className="h-[245px] md:h-[500px] bg-gray-200 flex items-center justify-center text-gray-500">
        Loading hero...
      </div>
    );
  }

  return (
    <div
      className="relative w-full h-[245px] md:h-[500px] overflow-hidden"
      onTouchStart={handleTouchStart}
      onTouchEnd={handleTouchEnd}
    >
      {/* TRACK */}
      <div
        className="flex h-full transition-transform duration-700 ease-in-out"
        style={{
          width: `${length * 100}%`,
          transform: `translateX(-${index * (100 / length)}%)`,
        }}
      >
        {heroPosts.map((post: any, i: number) => (
          <div
            key={post.id || i}
            className="h-full flex-shrink-0"
            style={{ width: `${100 / length}%` }}
          >
            <img
              src={getImage(post)}
              alt={post?.title?.rendered || "Hero"}
              className="w-full h-full object-cover"
            />
          </div>
        ))}
      </div>

      {/* NAV */}
      {length > 1 && (
        <>
          <button
            onClick={prevSlide}
            className="absolute left-4 top-1/2 -translate-y-1/2 bg-black/40 text-white px-4 py-2 rounded-full"
          >
            {"<"}
          </button>

          <button
            onClick={nextSlide}
            className="absolute right-4 top-1/2 -translate-y-1/2 bg-black/40 text-white px-4 py-2 rounded-full"
          >
            {">"}
          </button>

          <div className="absolute bottom-4 w-full flex justify-center gap-2">
            {heroPosts.map((_: any, i: number) => (
              <button
                key={i}
                onClick={() => setIndex(i)}
                className={`w-2.5 h-2.5 rounded-full transition ${
                  i === index ? "bg-white" : "bg-white/40"
                }`}
              />
            ))}
          </div>
        </>
      )}
    </div>
  );
}