"use client";

import { useEffect, useState, useRef } from "react";

export default function HeroSlider({ posts }: any) {
  const [index, setIndex] = useState(0);

  const startX = useRef(0);

  // maksimal 10 slide
  const heroPosts = posts?.slice(0, 10) || [];

  const length = heroPosts.length;

  // AUTO SLIDE
  useEffect(() => {
    if (length <= 1) return;

    const interval = setInterval(() => {
      setIndex((prev) => {
        if (prev >= length - 1) return 0;
        return prev + 1;
      });
    }, 4000);

    return () => clearInterval(interval);
  }, [length]);

  // NEXT
  const nextSlide = () => {
    setIndex((prev) => {
      if (prev >= length - 1) return 0;
      return prev + 1;
    });
  };

  // PREV
  const prevSlide = () => {
    setIndex((prev) => {
      if (prev <= 0) return length - 1;
      return prev - 1;
    });
  };

  // TOUCH START
  const handleTouchStart = (e: any) => {
    startX.current = e.touches[0].clientX;
  };

  // TOUCH END
  const handleTouchEnd = (e: any) => {
    const endX = e.changedTouches[0].clientX;

    if (startX.current - endX > 50) {
      nextSlide();
    }

    if (endX - startX.current > 50) {
      prevSlide();
    }
  };

  // GET IMAGE
  const getImage = (post: any) => {
    let img =
      post?._embedded?.["wp:featuredmedia"]?.[0]?.media_details?.sizes
        ?.medium_large?.source_url ||
      post?._embedded?.["wp:featuredmedia"]?.[0]?.media_details?.sizes
        ?.large?.source_url ||
      post?._embedded?.["wp:featuredmedia"]?.[0]?.source_url;

    if (img) {
      img = img.replace("http://", "https://");
    }

    return (
      img ||
      "https://cms.komunikasi.uinsgd.ac.id/wp-content/uploads/2026/04/selamat-1-1-1140x570.jpeg"
    );
  };

  // EMPTY
  if (!heroPosts || length === 0) {
    return (
      <div className="h-[200px] md:h-[500px] bg-gray-300 flex items-center justify-center">
        No Hero
      </div>
    );
  }

  return (
    <div
      className="relative w-full h-[200px] md:h-[500px] overflow-hidden"
      onTouchStart={handleTouchStart}
      onTouchEnd={handleTouchEnd}
    >
      {/* SLIDER */}
      <div
        className="flex h-full transition-transform duration-700 ease-in-out"
        style={{
          width: `${length * 100}%`,
          transform: `translateX(-${index * (100 / length)}%)`,
        }}
      >
        {heroPosts.map((post: any, i: number) => (
          <div
            key={i}
            className="h-full flex-shrink-0"
            style={{
              width: `${100 / length}%`,
            }}
          >
            <img
              src={getImage(post)}
              alt={post?.title?.rendered || "Hero"}
              className="w-full h-full object-cover"
              loading={i === 0 ? "eager" : "lazy"}
              fetchPriority={i === 0 ? "high" : "low"}
              onError={(e) => {
                e.currentTarget.src =
                  "https://cms.komunikasi.uinsgd.ac.id/wp-content/uploads/2026/04/selamat-1-1-1140x570.jpeg";
              }}
            />
          </div>
        ))}
      </div>

      {/* PREV */}
      {length > 1 && (
        <button
          onClick={prevSlide}
          className="absolute left-4 top-1/2 -translate-y-1/2 z-10 bg-black/40 hover:bg-black/60 text-white px-4 py-2 rounded-full transition"
        >
          {"<"}
        </button>
      )}

      {/* NEXT */}
      {length > 1 && (
        <button
          onClick={nextSlide}
          className="absolute right-4 top-1/2 -translate-y-1/2 z-10 bg-black/40 hover:bg-black/60 text-white px-4 py-2 rounded-full transition"
        >
          {">"}
        </button>
      )}

      {/* DOTS */}
      {length > 1 && (
        <div className="absolute bottom-4 w-full flex justify-center gap-2 z-10">
          {heroPosts.map((_: any, i: number) => (
            <button
              key={i}
              onClick={() => setIndex(i)}
              className={`w-3 h-3 rounded-full transition-all ${
                i === index
                  ? "bg-white scale-110"
                  : "bg-white/50"
              }`}
            />
          ))}
        </div>
      )}
    </div>
  );
}