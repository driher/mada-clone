export default function ProfileCard({
  label,
  name,
  image,
  content,
  color = "green",
}) {
  const colorMap = {
    green: "bg-green-600",
    pink: "bg-pink-500",
    orange: "bg-orange-500",
  };

  return (
    <div className="bg-white rounded-3xl shadow-md hover:shadow-xl transition-all duration-300 overflow-hidden">

      <div className="flex flex-col md:flex-row">

        {/* FOTO */}
        <div className="md:w-1/3 w-full h-64 md:h-auto overflow-hidden">
          <img
            src={image}
            className="w-full h-full object-cover"
          />
        </div>

        {/* TEXT */}
        <div className="flex-1 p-6 md:p-8 flex flex-col justify-center">

          {/* LABEL */}
          <span
            className={`inline-block text-xs font-semibold text-white px-3 py-1 rounded-full mb-3 ${colorMap[color]}`}
          >
            {label}
          </span>

          {/* NAMA */}
          <h2 className="text-xl md:text-2xl font-bold text-gray-900 leading-snug">
            {name}
          </h2>

          {/* GARIS AKSEN */}
          <div className={`w-12 h-1 ${colorMap[color]} mt-3 mb-4 rounded`} />

          {/* DESKRIPSI */}
          <p className="text-gray-600 text-sm md:text-base leading-relaxed">
            {content}
          </p>

        </div>
      </div>
    </div>
  );
}