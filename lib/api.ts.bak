const API_URL = "https://cms.komunikasi.uinsgd.ac.id/wp-json/wp/v2";

/* =========================
   BERITA (kategori 44)
========================= */
export async function getBerita() {
  try {
    const res = await fetch(
      `${API_URL}/posts?_embed&categories=44&per_page=6`,
      { next: { revalidate: 300 } }
    );

    if (!res.ok) return [];

    return await res.json();
  } catch (error) {
    console.error("getBerita error:", error);
    return [];
  }
}

