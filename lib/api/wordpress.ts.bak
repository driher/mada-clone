import { fetcher } from "../fetcher";

// HERO
export const getHeroPosts = () =>
  fetcher("/posts?categories=10&_embed&per_page=5", {
    revalidate: 30,
  });

// BERITA
export const getBeritaAgenda = () =>
  fetcher("/posts?categories=65&_embed&per_page=6", {
    revalidate: 30,
  });

