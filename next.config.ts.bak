import withPWA from "next-pwa";
import type { NextConfig } from "next";

const nextConfig: NextConfig = {
  turbopack: {},

  // ✅ FIX DEV ORIGINS (INI YANG BENER)
  allowedDevOrigins: [
    "localhost",
    "127.0.0.1",
    "http://localhost:3000",
    "http://127.0.0.1:3000",
  ],

  images: {
    remotePatterns: [
      {
        protocol: "https",
        hostname: "**",
      },
    ],
  },

  // API REWRITE
  async rewrites() {
    return [
      {
        source: "/api-proxy/:path*",
        destination: "https://cms.komunikasi.uinsgd.ac.id/:path*",
      },
    ];
  },

  // REDIRECT DOMAIN VERCEL → DOMAIN UTAMA
  async redirects() {
    return [
      {
        source: "/:path*",
        has: [
          {
            type: "host",
            value: "mada-clone.vercel.app",
          },
        ],
        destination: "https://komunikasi.uinsgd.ac.id/:path*",
        permanent: true,
      },
    ];
  },
};

export default withPWA({
  dest: "public",
  register: true,
  skipWaiting: true,
  disable: process.env.NODE_ENV === "development",
})(nextConfig);